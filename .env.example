# Example environment file for AegisGraph Sentinel 2.0
#
# 12-Factor App principles:
# - Config is environment-specific and injected via environment variables.
# - Environment variables override defaults and any YAML config.
# - Use consistent naming so the same app works across dev/stage/prod.
#
# Copy this file to `.env` and update values as needed.

# =========================
# API (service) settings
# =========================
API_HOST=0.0.0.0
API_PORT=8000
API_RELOAD=false
API_URL=http://localhost:8000
LOG_LEVEL=INFO
LOG_FORMAT=json

# Allowed origins for CORS (comma-separated).
# Each entry must be a valid origin: <scheme>://<host>[:<port>] — no path component.
# Valid:   http://localhost:3000,https://app.example.com
# Invalid: https:// (missing host), http://example.com/path (path not allowed), * (wildcard blocked)
CORS_ORIGINS=http://localhost:3000,http://localhost:8000

# Legacy alias for CORS_ORIGINS (optional; CORS_ORIGINS takes priority)
# AEGIS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8000

# Rate limit in the format: <number>/<unit> (e.g., 500/minute)
RATE_LIMIT=1000/minute

# Batch / chunk sizing
MAX_BATCH_SIZE=100

# =========================
# Security secrets
# =========================
# AEGIS_API_KEY_HASHES is the primary authentication backend. Role-protected
# endpoints (require_role) resolve the X-API-Key header against these hashes and
# return 503 for every request while none are configured, so this must be set for
# the API to serve traffic.
# Value is a comma-separated list of lowercase SHA-256 hashes, not raw keys.
# Generate a key and its hash with:
#   python -c "import secrets,hashlib; k=secrets.token_hex(32); print('key:',k); print('hash:',hashlib.sha256(k.encode()).hexdigest())"
# Keys matched here are granted SUPER_ADMIN.
AEGIS_API_KEY_HASHES=

# Optional role-scoped hashes. A key listed here receives that role instead of
# SUPER_ADMIN. Same comma-separated SHA-256 format as above.
# Role hierarchy: SUPER_ADMIN > ADMIN > (ANALYST | AUDITOR) > VIEWER
# AEGIS_ROLE_SUPER_ADMIN=
# AEGIS_ROLE_ADMIN=
# AEGIS_ROLE_ANALYST=
# AEGIS_ROLE_AUDITOR=
# AEGIS_ROLE_VIEWER=

# AEGIS_UI_API_KEY is the raw key the Streamlit UI sends as X-API-Key. It must be
# a key whose SHA-256 hash appears in one of the variables above, otherwise the UI
# receives 401 or 503 on every protected call.
AEGIS_UI_API_KEY=

# AEGIS_API_KEY is the legacy single-secret backend used by verify_api_key on a
# small number of routes. It is compared in plaintext and does not grant roles.
# Set it only if you depend on those routes.
AEGIS_API_KEY=dev-insecure-change-me-in-production

# SECRET_KEY is the primary signing key used for JWT tokens across the
# application.  Must be set explicitly when ENV=prod; the app raises a
# ConfigurationError at startup if it is missing in production.
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
# SECRET_KEY=change-me-to-a-random-64-hex-char-string

# Token hash for authenticating Prometheus /metrics endpoint scraping.
# When set, /metrics requires a Bearer token whose SHA-256 hash matches this value.
# Required in production: with AEGIS_ENV=production and this unset, /metrics returns
# 503 rather than serving telemetry anonymously. Other environments leave the
# endpoint open so local scraping keeps working.
# Generate a token and its hash with:
#   python -c "import secrets,hashlib; t=secrets.token_hex(32); print('token:',t); print('hash:',hashlib.sha256(t.encode()).hexdigest())"
# AEGIS_METRICS_SCRAPE_TOKEN_HASH=

# =========================
# Risk thresholds (0-1)
# Ordered so: allow <= review <= block
# =========================
RISK_THRESHOLD_ALLOW=0.40
RISK_THRESHOLD_REVIEW=0.65
RISK_THRESHOLD_BLOCK=0.85

# =========================
# Component weights (should sum to ~1.0)
# =========================
COMPONENT_WEIGHT_GRAPH=0.50
COMPONENT_WEIGHT_VELOCITY=0.20
COMPONENT_WEIGHT_BEHAVIOR=0.20
COMPONENT_WEIGHT_ENTROPY=0.10

# =========================
# Optional: feature flags / integrations
# =========================
# AEGIS_NEO4J_ENABLED=false
# AEGIS_NEO4J_URI=bolt://localhost:7687
# AEGIS_NEO4J_USER=neo4j
# AEGIS_NEO4J_PASSWORD=changeme

# Google Gemini API Key for AI Alert Summaries
# GEMINI_API_KEY=your_gemini_api_key_here

# =========================
# SSO / OAuth provider credentials
# Each provider is only registered if both CLIENT_ID and CLIENT_SECRET are set.
# =========================
# OAUTH_GOOGLE_CLIENT_ID=
# OAUTH_GOOGLE_CLIENT_SECRET=

# OAUTH_OKTA_CLIENT_ID=
# OAUTH_OKTA_CLIENT_SECRET=
# OAUTH_OKTA_DOMAIN=https://your-domain.okta.com

# OAUTH_AZURE_CLIENT_ID=
# OAUTH_AZURE_CLIENT_SECRET=
# OAUTH_AZURE_TENANT_ID=common

# Comma-separated list of permitted OAuth callback URIs (leave empty to allow
# any redirect_uri in development; always set this in production).
# OAUTH_REDIRECT_URIS=https://app.example.com/auth/callback

# =========================
# Real-Time Webhook Integrations  (Issue #633)
# =========================
#
# AegisGraph Sentinel can send real-time notifications to Discord and/or
# Slack whenever a HIGH-severity SentinelAlertEvent is emitted — for example
# when a fraud transaction is automatically blocked.
#
# Global kill-switch: set to "false" to silence all webhook notifications
# regardless of per-service settings below.
ENABLE_WEBHOOK_ALERTS=false

# --- Discord ---
# 1. In your Discord server → channel settings → Integrations → Webhooks.
# 2. Create or copy a Webhook URL (format: https://discord.com/api/webhooks/<id>/<token>).
# 3. Set ENABLE_DISCORD_WEBHOOK=true to activate.
DISCORD_WEBHOOK_URL=
ENABLE_DISCORD_WEBHOOK=false

# --- Slack ---
# 1. Visit https://api.slack.com/apps → Your App → Incoming Webhooks.
# 2. Activate incoming webhooks, add to workspace, copy the Webhook URL.
#    (format: https://hooks.slack.com/services/<T>/<B>/<token>)
# 3. Set ENABLE_SLACK_WEBHOOK=true to activate.
SLACK_WEBHOOK_URL=
ENABLE_SLACK_WEBHOOK=false

# =========================
# Archival / Data Lifecycle (Issue #1477)
# =========================
#
# AegisGraph Sentinel runs a background cron job that migrates aging logs from
# the primary hot collection to a cold-storage archive collection every night.
# This keeps real-time graph queries fast while retaining full historical data.
#
# ARCHIVAL_THRESHOLD_DAYS — logs older than this many days are moved to cold
#   storage.  Default: 30 days.
ARCHIVAL_THRESHOLD_DAYS=30
#
# ARCHIVAL_BATCH_SIZE — number of documents processed per internal batch within
#   a single archival run.  Larger values speed up big runs but hold the store
#   lock longer.  Default: 500.
ARCHIVAL_BATCH_SIZE=500
#
# ARCHIVAL_INTERVAL_HOURS — how often the scheduled archival cycle fires.
#   Default: 24 (once per day).
ARCHIVAL_INTERVAL_HOURS=24
